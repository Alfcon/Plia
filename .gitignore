# =====================================================
# Plia — .gitignore
# =====================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo

# ----- Virtual environments -----
venv/
.venv/
env/
.env/
ENV/

# ----- Conda -----
.conda/

# ----- Router model (auto-downloaded on first run) -----
# The merged_model directory is populated automatically from Hugging Face.
# Do not commit the model weights — they are ~500 MB.
merged_model/*.safetensors
merged_model/*.json
merged_model/*.bin
merged_model/.cache/
# Keep the directory itself so git tracks it
!merged_model/.gitkeep

# ----- Plia runtime data (auto-created, user-specific) -----
data/*.db
data/*.json
# Keep the directory
!data/.gitkeep

# ----- User config & model cache (~/.plia_ai/) -----
# This directory is outside the repo, but listed for clarity.
# Never commit user settings, TTS models, or API tokens.

# ----- Log files -----
*.log
realtimesst.log
import_error.txt
install_log.txt

# ----- Dev & training artifacts -----
plia_tree.txt
training_dataset.jsonl
training_dataset_functions.jsonl
chat_history.db

# ----- IDE / editor files -----
.vs/
.vscode/
.idea/
*.suo
*.user
*.sln
*.swp
*.swo
*~

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Secrets & credentials -----
*.env
secrets.json
credentials.json
token.json
google_token.json
outlook_token.json
.env.*

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb

# ----- PyInstaller -----
*.spec
dist/
build/

# ----- Coverage & testing -----
.coverage
htmlcov/
.pytest_cache/
.tox/

# ----- Hugging Face cache -----
.cache/
